---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import type { CollectionEntry } from 'astro:content';
import { projects } from './projects/_data';
import ProjectList from '../components/ProjectList.astro';
import PostItem from '../components/PostItem.astro';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog'))
	.sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<Hero />

		<main>
			<div
				class='mt-6 mb-8 border dark:border-zinc-700 rounded-xl p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-zinc-50 dark:bg-zinc-800/50'
			>
				<div>
					<p class='font-semibold text-base'>Need a website or web app?</p>
					<p class='text-sm text-zinc-500 dark:text-zinc-400 mt-0.5'>
						I take projects from idea to production — fast, scalable, and built to last.
					</p>
				</div>
				<a
					href='/hire-me/'
					class='shrink-0 inline-block bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 text-sm font-semibold px-4 py-2 rounded-lg hover:opacity-80 transition-opacity'
				>
					Let's Talk →
				</a>
			</div>

			<div class='mb-12'>
				<div class='flex justify-between gap-2'>
					<h2 class='text-lg font-bold mb-3'>Recent Posts</h2>
					<a href='/posts/' class='inline-block py-2 underline dark:prose-invert'>All posts &raquo;</a>
				</div>
				<div>
					{posts.map((post: BlogPost) => <PostItem post={post} />)}
				</div>
				<div class='text-right'></div>
			</div>

			<div>
				<div class='flex justify-between gap-2 mb-1'>
					<h2 class='text-lg font-bold mb-3'>My Projects</h2>
					<a href='/projects/' class='inline-block py-2 underline dark:prose-invert'>All projects &raquo;</a>
				</div>
				<ProjectList projects={top6Projects} />
			</div>
		</main>
	</div>
</BaseLayout>
